<resources>
    <string name="app_name">PokeChamps Supporter</string>

    <!-- ===== Onboarding (MainActivity) ===== -->
    <string name="onboarding_title">PokeChamps Supporter</string>
    <string name="onboarding_intro_title">What this app does</string>
    <string name="onboarding_intro_body">During a battle it reads the opponent Pokémon name shown on screen and displays its type, ability, and top moves over the game.\n\n• Only shows information already visible on screen.\n• Does not read game memory or auto-input anything.</string>

    <!-- ===== Legal notice (from K4 EULA research) ===== -->
    <string name="onboarding_legal_title">Before you use this</string>
    <string name="onboarding_legal_body">This app only displays opponent info already shown on screen; it never reads game memory, automates input, or modifies the game. However, The Pokémon Company (TPCi) terms and tournament rules broadly restrict unauthorized third-party software, and using assist tools in official ranked or Play! Pokémon (VGC) play may lead to disqualification.\n\n• Use for casual/practice only.\n• Close the app during official or tournament battles.\n• You alone bear the risk of any account penalty.</string>

    <string name="onboarding_step_overlay">1. Overlay permission</string>
    <string name="onboarding_overlay_granted">Granted ✓</string>
    <string name="onboarding_overlay_needed">To draw info cards over the game, the \'Display over other apps\' permission is required.</string>
    <string name="onboarding_overlay_open">Open permission settings</string>
    <string name="onboarding_overlay_recheck">I granted it (re-check)</string>

    <string name="onboarding_step_game">2. Game settings</string>
    <string name="onboarding_game_title">Turn on battle names</string>
    <string name="onboarding_game_body">In Pochamps → Settings, turn ON \'Display Battle Names\'.\nThe opponent name text must appear on screen to be recognized.</string>

    <string name="onboarding_step_run">3. Run</string>
    <string name="onboarding_start">Start (screen capture)</string>
    <string name="onboarding_need_overlay_first">Grant the overlay permission first.</string>
    <string name="onboarding_demo">Demo card (no capture)</string>
    <string name="onboarding_running_title">Running</string>
    <string name="onboarding_running_body">The overlay is shown over the game.\nA \'Capturing\' notification appears in the status bar.</string>
    <string name="onboarding_stop">Stop</string>

    <!-- ===== Settings ===== -->
    <string name="settings_title">Settings</string>
    <string name="settings_language_title">Game language</string>
    <string name="settings_language_desc">The language of opponent names shown in the game. The OCR recognizer and display language follow this value.\nChanges apply from the next run.</string>
    <string name="settings_roi_title">Advanced: recognition region (ROI)</string>
    <string name="settings_roi_desc">The screen region where opponent names are read. If you have a calibrated value, this resets it to the default.</string>
    <string name="settings_roi_reset">Reset ROI to default</string>
    <string name="settings_roi_reset_done">Reset to default ✓</string>
    <string name="settings_roi_calibrate">Calibrate name region (on screen)</string>
    <string name="settings_roi_calibrate_need_overlay">Overlay permission is required to show the calibration screen over the game.</string>

    <!-- ===== Diagnostics mode (P14 field-test support) ===== -->
    <string name="settings_diag_title">Diagnostics mode</string>
    <string name="settings_diag_desc">Shows why recognition fails, right away. Displays the last OCR text, match result, last-seen time, and OCR rate on the overlay. Applies from the next run.</string>
    <string name="settings_diag_on">Diagnostic strip: on</string>
    <string name="settings_diag_off">Diagnostic strip: off</string>

