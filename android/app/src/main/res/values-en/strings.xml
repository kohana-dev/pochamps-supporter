    <!-- ===== Onboarding (MainActivity) ===== -->
    <string name="onboarding_title">PokeChamps Supporter</string>
    <string name="onboarding_intro_title">What this app does</string>
    <string name="onboarding_intro_body">During a battle it reads the opponent Pokémon name shown on screen and displays its type, ability, and top moves over the game.\n\n• Only shows information already visible on screen.\n• Does not read game memory or auto-input anything.</string>

    <!-- ===== Legal notice (from K4 EULA research) ===== -->
    <string name="onboarding_legal_title">Before you use this</string>
    <string name="onboarding_legal_body">This app only displays opponent info already shown on screen; it never reads game memory, automates input, or modifies the game. However, The Pokémon Company (TPCi) terms and tournament rules broadly restrict unauthorized third-party software, and using assist tools in official ranked or Play! Pokémon (VGC) play may lead to disqualification.\n\n• Use for casual/practice only.\n• Close the app during official or tournament battles.\n• You alone bear the risk of any account penalty.</string>

    <string name="onboarding_step_overlay">1. Overlay permission</string>
    <string name="onboarding_overlay_granted">Granted ✓</string>
    <string name="onboarding_overlay_needed">To draw info cards over the game, the \'Display over other apps\' permission is required.</string>
    <string name="onboarding_overlay_open">Open permission settings</string>
    <string name="onboarding_overlay_recheck">I granted it (re-check)</string>

    <string name="onboarding_step_game">2. Game settings</string>
    <string name="onboarding_game_title">Turn on battle names</string>
    <string name="onboarding_game_body">In Pochamps → Settings, turn ON \'Display Battle Names\'.\nThe opponent name text must appear on screen to be recognized.</string>

