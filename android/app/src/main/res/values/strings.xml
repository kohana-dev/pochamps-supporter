<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string name="app_name">포챔스 서포터</string>

    <!-- ===== 온보딩(MainActivity) ===== -->
    <string name="onboarding_title">포챔스 서포터</string>
    <string name="onboarding_intro_title">이 앱이 하는 일</string>
    <string name="onboarding_intro_body">대전 중 화면에 보이는 상대 포켓몬 이름을 읽어, 타입·특성·주요기술을 게임 위에 표시합니다.\n\n• 화면에 이미 보이는 정보만 표시합니다.\n• 게임 메모리를 읽거나 자동 입력하지 않습니다.</string>

    <!-- ===== 법적 고지(K4 EULA 조사 반영) ===== -->
    <string name="onboarding_legal_title">이용 시 주의</string>
    <string name="onboarding_legal_body">본 앱은 화면에 이미 공개된 상대 정보만 표시하며, 게임 메모리 읽기·입력 자동화·게임 변조를 일절 하지 않습니다. 다만 포켓몬사(TPCi)의 이용약관·대회 규정은 비인가 서드파티 소프트웨어를 폭넓게 제한하며, 특히 공식 랭크전·Play! Pokémon(VGC) 등 공인 대회에서 보조 도구 사용은 실격 사유가 될 수 있습니다.\n\n• 캐주얼·연습 용도로만 사용하세요.\n• 공식·대회 대전에서는 앱을 종료하세요.\n• 계정 제재 위험은 사용자 본인 책임입니다.</string>

    <string name="onboarding_step_overlay">1. 오버레이 권한</string>
    <string name="onboarding_overlay_granted">허용됨 ✓</string>
    <string name="onboarding_overlay_needed">게임 위에 정보 카드를 띄우려면 \'다른 앱 위에 표시\' 권한이 필요합니다.</string>
    <string name="onboarding_overlay_open">권한 설정 열기</string>
    <string name="onboarding_overlay_recheck">허용했어요 (다시 확인)</string>

    <string name="onboarding_step_game">2. 게임 설정</string>
    <string name="onboarding_game_title">배틀명 표시 켜기</string>
    <string name="onboarding_game_body">포챔스 → 설정 → \'Display Battle Names\'(배틀명 표시)를 ON 으로 해주세요.\n상대 이름 텍스트가 화면에 떠야 인식할 수 있습니다.</string>

    <string name="onboarding_step_run">3. 실행</string>
    <string name="onboarding_start">시작 (화면 캡처)</string>
    <string name="onboarding_need_overlay_first">먼저 오버레이 권한을 허용하세요.</string>
    <string name="onboarding_demo">데모 카드 (캡처 없이)</string>
    <string name="onboarding_running_title">실행 중</string>
    <string name="onboarding_running_body">오버레이가 게임 위에 떠 있습니다.\n상태바에 \'캡처 중\' 알림이 표시됩니다.</string>
    <string name="onboarding_stop">중지</string>

    <!-- ===== 설정 섹션 ===== -->
    <string name="settings_title">설정</string>
    <string name="settings_language_title">게임 언어</string>
    <string name="settings_language_desc">게임 화면에 뜨는 상대 이름의 언어. OCR 인식기와 표시 언어가 이 값으로 맞춰집니다.\n변경은 다음 실행부터 적용됩니다.</string>
    <string name="settings_roi_title">고급: 인식 영역(ROI)</string>
    <string name="settings_roi_desc">상대 이름을 읽는 화면 영역입니다. 실기기 화면에 맞춰 보정한 값이 있으면 기본값으로 되돌립니다.</string>
    <string name="settings_roi_reset">ROI 기본값으로 리셋</string>
    <string name="settings_roi_reset_done">기본값으로 되돌림 ✓</string>
    <string name="settings_roi_calibrate">이름 영역 보정 (화면에서 직접)</string>
    <string name="settings_roi_calibrate_need_overlay">보정 화면을 게임 위에 띄우려면 오버레이 권한이 필요합니다.</string>

    <!-- ===== 진단 모드(P14 필드테스트 지원) ===== -->
    <string name="settings_diag_title">진단 모드</string>
    <string name="settings_diag_desc">인식이 안 될 때 원인을 바로 보여줍니다. 오버레이에 마지막 OCR 원문·매칭 결과·인식 시각·OCR 빈도를 표시합니다. 다음 실행부터 적용됩니다.</string>
    <string name="settings_diag_on">진단 스트립 표시 켜짐</string>
    <string name="settings_diag_off">진단 스트립 표시 꺼짐</string>

    <!-- ===== ROI 보정 오버레이(P14) ===== -->
    <string name="calib_hint">상대 이름표 위에 사각형을 맞추세요. 안쪽을 끌어 이동, 모서리를 끌어 크기 조절.</string>
