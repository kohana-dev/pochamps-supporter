<?xml version="1.0" encoding="utf-8"?>
<!--
  런처 아이콘 전경 레이어(어댑티브). 108x108dp, 중앙 72x72 세이프존 안에 모티브 배치.
  모티브 = 앱의 실제 오버레이 "정보 카드 + 타입칩" 실루엣(오리지널 디자인, 포켓몬 저작물 무사용).
  - 어두운 카드(#1A1A1A, 앱 CardBg 와 동일 톤)
  - 상단 포켓몬 이름줄(액센트 블루 #8AB4F8)
  - 하단 타입칩 2개(파랑/초록) — 타입 상성 표시가 앱의 핵심.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- 카드 그림자(살짝 아래로 오프셋된 어두운 판) -->
    <path
        android:pathData="M28,32 h52 a6,6 0 0 1 6,6 v36 a6,6 0 0 1 -6,6 h-52 a6,6 0 0 1 -6,-6 v-36 a6,6 0 0 1 6,-6 z"
        android:fillColor="#33000000" />

    <!-- 오버레이 카드 본체 -->
    <path
        android:pathData="M26,30 h52 a6,6 0 0 1 6,6 v36 a6,6 0 0 1 -6,6 h-52 a6,6 0 0 1 -6,-6 v-36 a6,6 0 0 1 6,-6 z"
        android:fillColor="#F21A1A1A" />

    <!-- 포켓몬 아이콘 자리(작은 원반) -->
    <path
        android:pathData="M32,40 m-5,0 a5,5 0 1 0 10,0 a5,5 0 1 0 -10,0 z"
        android:fillColor="#FF8AB4F8" />

    <!-- 이름줄(길게) + 짧은 서브줄 -->
    <path
        android:pathData="M42,37 h32 a2,2 0 0 1 0,4 h-32 a2,2 0 0 1 0,-4 z"
        android:fillColor="#FF8AB4F8" />
    <path
        android:pathData="M42,44 h20 a1.5,1.5 0 0 1 0,3 h-20 a1.5,1.5 0 0 1 0,-3 z"
        android:fillColor="#FFB0B0B0" />

    <!-- 타입칩 2개(파랑/초록) -->
    <path
        android:pathData="M28,56 h22 a4,4 0 0 1 4,4 v6 a4,4 0 0 1 -4,4 h-22 a4,4 0 0 1 -4,-4 v-6 a4,4 0 0 1 4,-4 z"
        android:fillColor="#FF4F86D8" />
    <path
        android:pathData="M58,56 h22 a4,4 0 0 1 4,4 v6 a4,4 0 0 1 -4,4 h-22 a4,4 0 0 1 -4,-4 v-6 a4,4 0 0 1 4,-4 z"
        android:fillColor="#FF6DAE4A" />
</vector>
