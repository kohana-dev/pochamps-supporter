<?xml version="1.0" encoding="utf-8"?>
<!-- 日本語(ja)。ko/ja/en は精度重視で翻訳。ポケモン用語(タイプ/とくせい/わざ)はカード側がデータ辞書の正確な9言語を使うため、ここは一般UI用語中心。 -->
<resources>
    <string name="app_name">ポケチャンプ サポーター</string>

    <!-- ===== オンボーディング(MainActivity) ===== -->
    <string name="onboarding_title">ポケチャンプ サポーター</string>
    <string name="onboarding_intro_title">このアプリの機能</string>
    <string name="onboarding_intro_body">対戦中、画面に表示された相手ポケモンの名前を読み取り、タイプ・とくせい・主要なわざをゲームの上に重ねて表示します。\n\n• 画面にすでに表示されている情報だけを表示します。\n• ゲームのメモリを読み取ったり自動入力したりしません。</string>

    <!-- ===== 法的注意(K4 EULA 調査) ===== -->
    <string name="onboarding_legal_title">ご利用の前に</string>
    <string name="onboarding_legal_body">本アプリは画面にすでに表示されている相手情報のみを表示し、ゲームメモリの読み取り・入力の自動化・ゲームの改変は一切行いません。ただし、株式会社ポケモン(TPCi)の利用規約・大会規定は非公認のサードパーティ製ソフトウェアを広く制限しており、特に公式ランクマッチや Play! Pokémon(VGC)などの公認大会で補助ツールを使用すると失格になる場合があります。\n\n• カジュアル・練習用途のみでご使用ください。\n• 公式・大会の対戦ではアプリを終了してください。\n• アカウント処分のリスクはご自身の責任となります。</string>

    <string name="onboarding_step_overlay">1. オーバーレイ権限</string>
    <string name="onboarding_overlay_granted">許可済み ✓</string>
    <string name="onboarding_overlay_needed">ゲームの上に情報カードを表示するには「他のアプリの上に重ねて表示」の権限が必要です。</string>
    <string name="onboarding_overlay_open">権限設定を開く</string>
    <string name="onboarding_overlay_recheck">許可しました(再確認)</string>

    <string name="onboarding_step_game">2. ゲーム設定</string>
    <string name="onboarding_game_title">バトル名の表示をオンに</string>
    <string name="onboarding_game_body">ポケチャンプ → 設定 →「Display Battle Names(バトル名の表示)」をオンにしてください。\n相手の名前テキストが画面に表示されないと認識できません。</string>

    <string name="onboarding_step_run">3. 実行</string>
    <string name="onboarding_start">開始(画面キャプチャ)</string>
    <string name="onboarding_need_overlay_first">先にオーバーレイ権限を許可してください。</string>
    <string name="onboarding_demo">デモカード(キャプチャなし)</string>
    <string name="onboarding_running_title">実行中</string>
    <string name="onboarding_running_body">オーバーレイがゲームの上に表示されています。\nステータスバーに「キャプチャ中」の通知が表示されます。</string>
    <string name="onboarding_stop">停止</string>

    <!-- ===== 設定 ===== -->
    <string name="settings_title">設定</string>
    <string name="settings_display_lang_title">アプリの表示言語</string>
    <string name="settings_display_lang_desc">アプリ画面と情報カード(ポケモンの名前・タイプ・とくせい・わざ)を表示する言語です。ゲーム画面の言語とは別に選べます。変更すると即座に反映されます。</string>
    <string name="settings_language_title">ゲーム画面の言語(認識用)</string>
    <string name="settings_language_desc">ゲーム画面に表示される相手の名前の言語です。OCR 認識をこの言語に合わせます(表示言語とは別)。変更は次回の実行から反映されます。</string>
    <string name="settings_roi_title">詳細設定:認識領域(ROI)</string>
    <string name="settings_roi_desc">相手の名前を読み取る画面領域です。調整した値がある場合は初期値に戻します。</string>
    <string name="settings_roi_reset">ROI を初期値にリセット</string>
    <string name="settings_roi_reset_done">初期値に戻しました ✓</string>
    <string name="settings_roi_calibrate">名前領域を調整(画面上で直接)</string>
    <string name="settings_roi_calibrate_need_overlay">調整画面をゲームの上に表示するにはオーバーレイ権限が必要です。</string>

    <!-- ===== オーバーレイカードのサイズ(P16) ===== -->
    <string name="settings_scale_title">オーバーレイカードのサイズ</string>
    <string name="settings_scale_desc">ゲームの上に表示される情報カードのサイズです。端末で大きすぎ・小さすぎる場合は調整してください。変更は即座に反映されます。</string>

    <!-- ===== バトル形式 シングル/ダブル(P20) ===== -->
    <string name="settings_format_title">バトル形式</string>
    <string name="settings_format_desc">シングル/ダブルに応じて、認識領域(シングル1つ/ダブル2つ)とわざの使用率(シングル対ダブルの環境)が切り替わります。オーバーレイのクイック切替で対戦ごとに変更できます。</string>
    <string name="format_single">シングル</string>
    <string name="format_doubles">ダブル</string>

    <!-- ===== 診断モード(P14 フィールドテスト支援) ===== -->
    <string name="settings_diag_title">診断モード</string>
    <string name="settings_diag_desc">認識できないときに原因をすぐ表示します。最後の OCR 原文・マッチ結果・認識時刻・OCR 頻度をオーバーレイに表示します。次回の実行から反映されます。</string>
    <string name="settings_diag_on">診断ストリップ表示:オン</string>
    <string name="settings_diag_off">診断ストリップ表示:オフ</string>

    <!-- ===== ROI 調整オーバーレイ(P14) ===== -->
    <string name="calib_hint">相手の名前プレートに枠を合わせてください。内側をドラッグで移動、角をドラッグでサイズ変更。</string>
    <string name="calib_single">シングル(1つ)</string>
    <string name="calib_doubles">ダブル(2つ)</string>
    <string name="calib_reset">リセット</string>
    <string name="calib_save">保存</string>
    <string name="calib_close">閉じる</string>

    <!-- ===== 診断ストリップ(オーバーレイ) ===== -->
